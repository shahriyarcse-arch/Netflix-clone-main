pipeline {
    agent any
    tools {
        jdk 'jdk17'
        nodejs 'node16'
    }
    environment {
        SCANNER_HOME = tool 'sonar-scanner'
    }
    stages {
        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/0sifat/Netflix-clone-main.git'
            }
        }
        stage('Install Dependencies') {
            steps {
                sh "npm install"
            }
        }
        stage('Build') {
            steps {
                sh "npx vite build"
            }
        }
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonar-server') {
                    sh '''
                    $SCANNER_HOME/bin/sonar-scanner \
                    -Dsonar.projectName=Netflix \
                    -Dsonar.projectKey=netflix-clone \
                    -Dsonar.sources=.
                    '''
                }
            }
        }
        stage('Quality Gate') {
            steps {
                waitForQualityGate abortPipeline: false
            }
        }
        stage('TRIVY FS SCAN') {
            steps {
                sh "trivy fs . > trivyfs.txt"
            }
        }
        stage('Docker Build & Push') {
            steps {
                script {
                    withDockerRegistry(credentialsId: 'docker', toolName: '') {
                        sh "docker build --no-cache --build-arg TMDB_V3_API_KEY=1a17f5f485f1ca37b72d16af9e0ff101 -t netflix ."
                        sh "docker tag netflix 1735332/netflix:latest"
                        sh "docker push 1735332/netflix:latest"
                    }
                }
            }
        }
        stage('Deploy to Container') {
            steps {
                sh "docker stop netflix || true"
                sh "docker rm netflix || true"
                sh "docker run -d --name netflix -p 8081:80 1735332/netflix:latest"
            }
        }
    }
}
